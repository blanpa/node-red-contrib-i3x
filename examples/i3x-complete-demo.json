                "pipeline-extract"
            ]
        ]
    },
    {
        "id": "pipeline-extract",
        "type": "function",
        "z": "i3x-demo-tab",
        "name": "2. Extract Element IDs",
        "func": "const ids = msg.payload.map(obj => obj.elementId);\n\nmsg.elementIds = ids;\nmsg.payload = {\n    count: ids.length,\n    ids: ids\n};\n\nnode.status({text: ids.length + \" objects found\"});\nreturn msg;",
        "outputs": 1,
        "timeout": "",
        "noerr": 0,
        "initialize": "",
        "finalize": "",
