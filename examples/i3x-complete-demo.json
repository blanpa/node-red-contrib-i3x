    {
        "id": "pipeline-browse",
        "type": "i3x-browse",
        "z": "i3x-demo-tab",
        "name": "1. All Objects",
        "server": "i3x-demo-server",
        "browseTarget": "objects",
        "elementId": "",
        "typeId": "",
        "namespaceUri": "",
        "includeMetadata": false,
        "relationshipType": "",
        "x": 390,
        "y": 1600,
        "wires": [
